<svg xmlns="http://www.w3.org/2000/svg" width="640" height="360" viewBox="0 0 640 360">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0f0c29"/>
      <stop offset="50%" style="stop-color:#302b63"/>
      <stop offset="100%" style="stop-color:#24243e"/>
    </linearGradient>
    <linearGradient id="accent" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#6c63ff"/>
      <stop offset="100%" style="stop-color:#00d4ff"/>
    </linearGradient>
  </defs>
  <rect width="640" height="360" fill="url(#bg)"/>
  <circle cx="100" cy="80" r="120" fill="rgba(108,99,255,0.1)"/>
  <circle cx="540" cy="280" r="100" fill="rgba(0,212,255,0.08)"/>
  <text x="320" y="155" font-family="Arial" font-size="72" text-anchor="middle" fill="url(#accent)" opacity="0.6">📖</text>
  <text x="320" y="215" font-family="Arial" font-size="22" font-weight="bold" text-anchor="middle" fill="rgba(255,255,255,0.8)">AdaptLearn Course</text>
  <rect x="240" y="230" width="160" height="3" rx="1.5" fill="url(#accent)" opacity="0.5"/>
</svg>
